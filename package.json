{
  "name": "copy-to-clipboard",
  "version": "3.3.3",
  "description": "Copy stuff into clipboard using JS with fallbacks",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "bundle": "browserify ./index.js --standalone copyToClipboard | uglifyjs -cm > example/index.js",
    "pretest": "npm run bundle",
    "test": "nightwatch --env chrome",
    "test:chrome": "nightwatch --env chrome",
    "test:firefox": "nightwatch --env firefox",
    "test:safari": "nightwatch --env safari",
    "test:all": "nightwatch --env chrome,firefox,safari"
  },
  "keywords": [
    "clipboard",
    "copy",
    "browser"
  ],
  "author": "sudodoki <smd.deluzion@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sudodoki/copy-to-clipboard"
  },
  "contributors": [
    {
      "name": "Aleksej Shvajka",
      "url": "https://github.com/shvaikalesh"
    }
  ],
  "dependencies": {
    "toggle-selection": "^1.0.6"
  },
  "directories": {
    "example": "example"
  },
  "devDependencies": {
    "@brettz9/node-static": "^0.1.1",
    "browserify": "^13.0.1",
    "chromedriver": "^146.0.6",
    "geckodriver": "^6.1.0",
    "minimist": "^1.2.6",
    "nightwatch": "^3.15.0",
    "uglify-js": "^3.5.3"
  }
}
