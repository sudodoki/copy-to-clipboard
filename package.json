{
  "name": "copy-to-clipboard",
  "version": "4.0.2",
  "description": "Copy stuff into clipboard using JS with fallbacks",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "type": "commonjs",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "changelog": "npx changelogen@0.6.2 --no-bump --output CHANGELOG.md",
    "release:patch": "npx changelogen@0.6.2 --release --patch",
    "release:minor": "npx changelogen@0.6.2 --release --minor",
    "release:major": "npx changelogen@0.6.2 --release --major",
    "build": "tsup && cp dist/index.global.js example/index.js",
    "typecheck": "tsc --noEmit",
    "check": "publint",
    "pretest": "npm run build",
    "test": "nightwatch --env chrome",
    "test:chrome": "nightwatch --env chrome",
    "test:firefox": "nightwatch --env firefox",
    "test:safari": "nightwatch --env safari",
    "test:edge": "nightwatch --env edge",
    "test:all": "nightwatch --env chrome,firefox,edge,safari",
    "test:lt:firefox": "nightwatch --env lambdatest_firefox",
    "test:lt:chrome": "nightwatch --env lambdatest_chrome",
    "test:lt:safari": "nightwatch --env lambdatest_safari",
    "test:lt:edge": "nightwatch --env lambdatest_edge",
    "test:lt:all": "nightwatch --env lambdatest_firefox,lambdatest_chrome,lambdatest_safari,lambdatest_edge"
  },
  "keywords": [
    "clipboard",
    "copy",
    "browser"
  ],
  "author": "sudodoki <smd.deluzion@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sudodoki/copy-to-clipboard.git"
  },
  "contributors": [
    {
      "name": "Aleksej Shvajka",
      "url": "https://github.com/shvaikalesh"
    }
  ],
  "directories": {
    "example": "example"
  },
  "devDependencies": {
    "@brettz9/node-static": "^0.1.1",
    "chromedriver": "^146.0.6",
    "geckodriver": "^6.1.0",
    "minimist": "^1.2.6",
    "nightwatch": "^3.15.0",
    "publint": "^0.3.18",
    "toggle-selection": "^2.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
